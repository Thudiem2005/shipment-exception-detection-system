      "parameters": {
        "jsCode": "return items.map(item => {\n  const d = item.json.delay_days;\n\n  let severity = \"LOW\";\n\n  if (d > 10) severity = \"HIGH\";\n  else if (d >= 5) severity = \"MEDIUM\";\n\n  item.json.severity = severity;\n\n  return item;\n});"
      },
