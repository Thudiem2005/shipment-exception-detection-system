        "jsCode": "const result = {};\n\nitems.forEach(item => {\n  const s = item.json.severity;\n\n  if (!result[s]) result[s] = 0;\n  result[s]++;\n});\n\nreturn [{\n  json: {\n    summary: result\n  }\n}];"
      },
